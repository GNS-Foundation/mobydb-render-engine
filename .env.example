# =============================================================================
# MobyDB Render Engine — canonical environment variable reference
# =============================================================================
# Copy this file to `.env` for local development. Never commit `.env`.
# For Railway deployment, set these in the service's Variables tab.
# For production: all secrets should come from Railway/Vault, never disk.
#
# Variable grouping:
#   1. Runtime                  (ENV, RUST_LOG, service ports)
#   2. Database (MobyDB)        (Postgres-compatible, shared instance)
#   3. Tenancy                  (tenant_id, RLS session var name)
#   4. Auth                     (OAuth2 + API key bootstrap)
#   5. Supabase (GEIANT)        (for Hive/AgentCore integration)
#   6. Observability            (OTLP, telemetry)
#   7. Render engine limits     (viewport bounds, cache, H3 resolution)
#   8. Deployment metadata      (Railway, git SHA, build info)
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Runtime
# -----------------------------------------------------------------------------
ENV=development                         # development | staging | production
RUST_LOG=info,mcp_server=debug,render_core=debug,mobydb_client=info
RUST_BACKTRACE=1                        # 0 | 1 | full — only for dev/staging

MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080

# MCP transport selection: "http" (default, for Railway) | "stdio" (for local agents)
MCP_TRANSPORT=http

# -----------------------------------------------------------------------------
# 2. Database — shared MobyDB (Phase 1 Railway, Phase 2 dedicated)
# -----------------------------------------------------------------------------
# Full connection URL. Railway auto-injects this for Postgres plugins.
# Format: postgres://user:pass@host:port/dbname?sslmode=require
DATABASE_URL=postgres://mobydb:CHANGEME@localhost:5432/mobydb_render

# Connection pool sizing
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=2
DATABASE_CONNECT_TIMEOUT_SEC=10
DATABASE_IDLE_TIMEOUT_SEC=300

# Run sqlx migrations on startup (set to 0 in production; use `sqlx migrate run` in CI)
DATABASE_MIGRATE_ON_START=1

# -----------------------------------------------------------------------------
# 3. Tenancy — multi-tenant via Postgres RLS
# -----------------------------------------------------------------------------
# The Postgres session variable name used by RLS policies.
# Policies filter WHERE tenant_id = current_setting('app.current_tenant_id')::uuid
TENANCY_SESSION_VAR=app.current_tenant_id

# Default tenant for this deployment (UUID). In multi-tenant mode, this is
# overridden per-request from the auth token's tenant claim.
TENANT_ID_DEFAULT=00000000-0000-0000-0000-000000000000

# Enforce tenant_id on every query (fail closed if not set). Never disable in prod.
TENANCY_STRICT=1

# -----------------------------------------------------------------------------
# 4. Auth
# -----------------------------------------------------------------------------
# Primary: MCP OAuth2. Bootstrap/CI: AUTH_API_KEY.
AUTH_API_KEY=                           # set to a random 32+ byte hex for bootstrap access
AUTH_API_KEY_HEADER=x-mobydb-api-key

OAUTH_ENABLED=0                         # 0 | 1 — enable in staging/prod
OAUTH_ISSUER=https://auth.geiant.com
OAUTH_AUDIENCE=mobydb-render-engine
OAUTH_JWKS_URL=https://auth.geiant.com/.well-known/jwks.json
OAUTH_JWKS_CACHE_SEC=3600

# Tenant claim name in the JWT. Resolved to TENANT_ID at request time.
OAUTH_TENANT_CLAIM=tenant_id

# -----------------------------------------------------------------------------
# 5. Supabase — GEIANT project (Hive + AgentCore)
# -----------------------------------------------------------------------------
# Ref: kaqwkxfaclyqjlfhxrmt (GEIANT, not the GNS-NETWORK project)
SUPABASE_URL=https://kaqwkxfaclyqjlfhxrmt.supabase.co
SUPABASE_SERVICE_KEY=                   # service_role key; NEVER expose to client
SUPABASE_ANON_KEY=                      # only used for clients; not needed for render-engine

# -----------------------------------------------------------------------------
# 6. Observability
# -----------------------------------------------------------------------------
OTEL_ENABLED=0                          # 0 | 1
OTEL_EXPORTER_OTLP_ENDPOINT=            # e.g. https://otel.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=             # e.g. Authorization=Bearer%20...
OTEL_SERVICE_NAME=mobydb-render-engine
OTEL_SERVICE_VERSION=0.1.0

# Prometheus metrics endpoint (exposed on MCP_SERVER_PORT at /metrics)
METRICS_ENABLED=1

# -----------------------------------------------------------------------------
# 7. Render engine limits
# -----------------------------------------------------------------------------
# Maximum cells that can be returned in a single viewport query. Hard ceiling.
MAX_VIEWPORT_CELLS=4096

# Default H3 resolution when client does not specify (0-15, typical 8-11)
DEFAULT_H3_RESOLUTION=9

# Compositor cache directory (local, ephemeral on Railway)
RENDER_CACHE_DIR=/tmp/mobydb-render-cache
RENDER_CACHE_MAX_MB=512

# P99 latency budget (ms) — if exceeded, emit a warning metric
RENDER_P99_BUDGET_MS=50

# -----------------------------------------------------------------------------
# 8. Deployment metadata (auto-injected by Railway / CI — leave blank locally)
# -----------------------------------------------------------------------------
RAILWAY_ENVIRONMENT=                    # production | preview | (blank local)
RAILWAY_SERVICE_NAME=
RAILWAY_DEPLOYMENT_ID=
GIT_SHA=                                # short SHA, filled by Docker build ARG
BUILD_TIME=                             # ISO-8601, filled at build time
