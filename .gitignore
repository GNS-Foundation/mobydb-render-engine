# Rust
/target/
**/*.rs.bk
Cargo.lock.bak

# Secrets & local env — NEVER commit
.env
.env.*
!.env.example

# Platform / editor
.DS_Store
.idea/
.vscode/
!.vscode/extensions.json
*.swp
*.swo

# Build / cache
/dist/
/build/
node_modules/
*.log

# Local runtime artifacts
/tmp/
/var/
*.pid
*.sock

# Coverage
/coverage/
/tarpaulin-report.html
*.profraw

# Docker
.dockerignore.local

# OS
Thumbs.db

# MobyDB render engine specific
/render-cache/
/snapshots/

# Demo app — local-only files
# demo/config.js holds the demo API key (inject via window.MOBYDB_DEMO_KEY)
# demo/fixtures is a symlink created by demo/setup_dev.sh so the demo can
# reach ../fixtures/ through python3 -m http.server (which doesn't follow ..)
demo/config.js
demo/fixtures
